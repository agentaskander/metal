{
  "name": "metal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:master",
    "dev:master": "vite --host 127.0.0.1 --port 8190 --strictPort",
    "dev:beta": "vite --host 127.0.0.1 --port 8192 --strictPort",
    "dev:public": "vite --host 127.0.0.1 --port 8193 --strictPort",
    "pages:master": "npm run build && npx wrangler pages dev ./dist --ip 127.0.0.1 --port 8190",
    "pages:beta": "npm run build && npx wrangler pages dev ./dist --ip 127.0.0.1 --port 8192",
    "pages:public": "npm run build && npx wrangler pages dev ./dist --ip 127.0.0.1 --port 8193",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^1.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
